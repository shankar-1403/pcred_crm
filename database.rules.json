        ".write": "auth != null && (auth.uid === $uid || root.child('users/' + auth.uid + '/role').val() === 'admin' || auth.uid === 'thy1xXKWoQXShRv3g31vuE180Uh1')"
      }
    },
    "leads": {
      ".read": true,
      ".write": true
    },
    "products": {
      ".read": true,
      ".write": "auth != null && root.child('users/' + auth.uid + '/role').val() === 'admin'"
    },
    "category": {
      ".read": true,
      ".write": "auth != null && root.child('users/' + auth.uid + '/role').val() === 'admin'"
    },
    "services": {
      ".read": true,
      ".write": "auth != null && root.child('users/' + auth.uid + '/role').val() === 'admin'"
    },
    "statuses": {
      ".read": true,
      ".write": "auth != null && root.child('users/' + auth.uid + '/role').val() === 'admin'"
    },
    "elite_ambassador": {
      ".read": true,
      ".write": "auth != null"
    },
    "ambassador": {
      ".read": true,
      ".write": "auth != null"
    },
    "creatives": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
